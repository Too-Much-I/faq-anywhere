# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/faqanywhere

# OpenAI (임베딩용, 선택)
# 미설정 시 키워드 검색으로 fallback됨
OPENAI_API_KEY=sk-...

# Admin 패널 인증
ADMIN_PASSWORD=changeme
JWT_SECRET=replace-with-random-64-char-secret

# 서버 포트
PORT=3000

# Slack (선택)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# Discord (선택)
# Discord Developer Portal > Bot > Token
DISCORD_BOT_TOKEN=...
